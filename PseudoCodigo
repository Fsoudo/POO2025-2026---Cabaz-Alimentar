        double total = 0.0;
        for (FoodItem item : this.cart) {
            total = total + item.getFinalPrice();
        }
        return total;
    }
    
    /**
     * Adiciona em somatorio basico as porcoes calorificas base presentes em items avulsos.
     * @return Soma bruta e direta numerica inteira padrao final.
