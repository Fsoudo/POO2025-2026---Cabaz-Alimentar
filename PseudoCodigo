public class BulkFood extends FoodItem {
    
    private static final double GRAMS_IN_KILO = 1000.0;
    private int currentWeightGrams;
    
    /**
     * Gera produto inicial livre para receber pesos do utilizador.
     * @param id identificador basico inicial.
     * @param name Nome exibido na interface global.
     * @param basePrice Valor tabelado ao kilograma.
     * @param category Familia de dieta de piramide alimentar.
     * @param kcal Calorias relativas ou intelectuais base genericas dadas.
     */
    public BulkFood(String id, String name, double basePrice, FoodGroup category, int kcal) {
        super(id, name, basePrice, category, kcal);
        this.currentWeightGrams = 0;
    }
    
    /**
     * Define dinamicamente as gramas requeridas atraves do UI para os calculos monetarios locais deste elemento isolado.
     * @param grams Gramas capturadas do util.
     */
    @Override
    public void setWeight(int grams) {
        this.currentWeightGrams = grams;
    }
    
    /**
     * Devolve o custo final usando a constante e regra matematica da propria classe do dominio em si so. Em conformidade oop.
     * @return Total das multiplicacoes e divisoes por kilo das escalas.
     */
    @Override
    public double getFinalPrice() {
        return (this.getBasePrice() / BulkFood.GRAMS_IN_KILO) * this.currentWeightGrams;
    }
    
    /**
     * Notifica a interfaçe Controller por polimofrismo que requer o alert extra interativo.
     * @return Retorna verdadeiro sem recorrer a metadados instaceof limitados pelas regras RPB.
     */
    @Override
    public boolean requiresWeightInteraction() {
        return true;
    }

    /**
     * Constroi clona unica nova evitando contaminacao da listagem visual global partilhada no reader centralizado inicial.
     * @return Reparticao unica limpa de Bulk.
     */
    @Override
    public FoodItem cloneItem() {
        return new BulkFood(this.getId(), this.getName(), this.getBasePrice(), this.getCategory(), this.getKcal());
    }
}
