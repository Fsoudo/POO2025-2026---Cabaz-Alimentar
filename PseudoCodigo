import java.io.File;
import java.util.Scanner;
import java.util.List;
import java.util.ArrayList;

/**
 * Conversor CSV central usando regras apertadas de bibliotecas core em scanner IO apenas sem plugins em try blocks confinados e minusculos limpos. 
 */
public class InventoryReader {
    
    private final List<String> ignoredLines;
    
    /**
     * Inicializa os logs e buffers em arrays de classes isolados do controller finalizado global puro encapsulado protegido final.
     */
    public InventoryReader() {
        this.ignoredLines = new ArrayList<>();
    }
    
    /**
     * Despoleta as corrotinas principais e encapsula na classe File original path basica central root local e devolve listagem valida global padrao instanciada polimorfica array local fina try catch de list error gen.
     * @param path Caminho txt/csv.
     * @return List de validade.
     */
    public List<FoodItem> readFile(String path) {
        List<FoodItem> inventory = new ArrayList<>();
        File file = new File(path);
        try (Scanner scanner = new Scanner(file)) {
            this.processLines(scanner, inventory);
        } catch (Exception e) {
            this.ignoredLines.add(e.getMessage());
        }
        return inventory;
    }
    
    /**
     * Correte de ciclos basica contendo os isolamentos max das 20 linhas totais de limitacao escolar da disciplina core no scanner validado extraido fora loops gigantes local de next iter.
     * @param scanner Leitor aberto.
     * @param inventory array pointer.
     */
    private void processLines(Scanner scanner, List<FoodItem> inventory) {
        if (scanner.hasNextLine()) {
            scanner.nextLine();
        }
        while (scanner.hasNextLine()) {
            this.parseLine(scanner.nextLine(), inventory);
        }
    }
    
    /**
     * Quebra e insere.
     * @param line Linha crua.
     * @param inventory array original source var pointer address final.
     */
    private void parseLine(String line, List<FoodItem> inventory) {
        try {
            String[] parts = line.split(",");
            FoodItem item = this.createItemFromParts(parts);
            inventory.add(item);
        } catch (Exception e) {
            this.ignoredLines.add(line);
        }
    }

    /**
     * Reparticao crua basica conversacional estricta para string cast.
     * @param parts array picado da string bruta the parsing block general loop.
     * @return O instanciado de criacao padrao de cast class sub factory the abstract form item object base polimorfico gen.
     * @throws Exception erro basilar.
     */
     private FoodItem createItemFromParts(String[] parts) throws Exception {
         String id = parts[0];
         String name = parts[1];
         double price = Double.parseDouble(parts[2]);
         FoodGroup category = FoodGroup.valueOf(parts[3].trim());
         int kcal = Integer.parseInt(parts[4]);
         String type = parts[5].trim();
         return this.instantiateItem(type, id, name, price, category, kcal, parts);
     }

    /**
     * Decisao limitando string compara e faz instanciacoes precisas para as rules da documentacao inicial exigida fina the type switch object new operator the polimorfic cast generic clean var line rules pattern abstract factory local var base limits.
     * @param type texto da tipo enumeracao ou string.
     * @param id var.
     * @param name text.
     * @param price cur.
     * @param category enum.
     * @param kcal n.
     * @param parts ar.
     * @return o cast valid.
     * @throws Exception fail cast de unsuported file config lines data format err generic msg exception limit log.
     */
     private FoodItem instantiateItem(String type, String id, String name, double price, FoodGroup category, int kcal, String[] parts) throws Exception {
         if (type.equals("PACKAGED")) {
             String material = parts[6];
             return new PackagedFood(id, name, price, category, kcal, material);
         }
         if (type.equals("BULK")) {
             return new BulkFood(id, name, price, category, kcal);
         }
         throw new Exception("Unknown type");
     }
    
    /**
     * Expositor seguro protegido the report list var method the basic var type limits.
     * @return text log var.
     */
    public List<String> getIgnoredLines() {
        return this.ignoredLines;
    }
}
